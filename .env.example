# Valores públicos y seguros por defecto.
# Ajusta un `.env` local o usa `config-privado/` para tus valores reales.

SERVER_BIND_IP=127.0.0.1
HOMEPAGE_ALLOWED_HOSTS=localhost:3000,127.0.0.1:3000
DASHBOARD_CONFIG_DIR=./configs/homepage

HOMEPAGE_IMAGE=ghcr.io/gethomepage/homepage:v1.10.1
GLANCES_IMAGE=nicolargo/glances:latest
PORTAINER_IMAGE=portainer/portainer-ce:latest

GLANCES_OPT=-w
