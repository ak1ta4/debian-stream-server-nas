[Unit]
Description=Docker Dashboard Stack (Homepage+Glances+Proxy)
After=docker.service
Requires=docker.service

[Service]
Type=oneshot
WorkingDirectory=/srv/docker/dashboard/stack
ExecStart=/usr/bin/docker compose up -d
ExecStop=/usr/bin/docker compose down
RemainAfterExit=yes
TimeoutStartSec=0

[Install]
WantedBy=multi-user.target
